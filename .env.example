# OpenAI API Key
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic API Key (Claude)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# 阿里云灵积 API Key (通义千问)
DASHSCOPE_API_KEY=sk-your-dashscope-key-here

# 使用说明：
# 1. 复制此文件为 .env
# 2. 填入你的实际 API Key
# 3. 运行: source .env
# 4. 启动应用: mvn spring-boot:run
