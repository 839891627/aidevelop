# ============================================
# AI 聊天助手环境变量配置示例
# ============================================
# 使用说明：
# 1. 复制此文件为 .env: cp .env.example .env
# 2. 填入你的实际配置信息
# 3. .env 文件已在 .gitignore 中，不会提交到 Git

# ============================================
# 数据库配置
# ============================================
# 数据库连接 URL
DB_URL=jdbc:mysql://localhost:3306/ai_develop?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true

# 数据库用户名
DB_USERNAME=root

# 数据库密码
DB_PASSWORD=your-database-password-here

# ============================================
# DeepSeek / OpenAI 配置
# ============================================
# OpenAI 兼容的 API Key（DeepSeek）
OPENAI_API_KEY=sk-your-deepseek-api-key-here

# OpenAI 兼容的 API 地址（DeepSeek 官方地址）
OPENAI_BASE_URL=https://api.deepseek.com

# ============================================
# Anthropic (Claude) 配置
# ============================================
# Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Anthropic API 地址
ANTHROPIC_BASE_URL=https://api.anthropic.com

# ============================================
# 智谱 AI 配置（用于 RAG 向量化）
# ============================================
# 智谱 AI API Key
ZHIPUAI_API_KEY=your-zhipuai-api-key-here

# ============================================
# 快速开始指南
# ============================================
# 1. 安装数据库并执行 SQL:
#    mysql -u root -p < sql/demo_tables.sql
#
# 2. 复制并配置环境变量:
#    cp .env.example .env
#    vim .env  # 填入你的 API Key 和数据库密码
#
# 3. 启动应用:
#    mvn clean spring-boot:run
#
# 4. 访问文档:
#    Swagger UI: http://localhost:8080/swagger-ui.html
#    Knife4j:    http://localhost:8080/doc.html
